# Copy to .env.development for local dev (Vite loads it automatically).
# Frontend: npm run dev → http://localhost:5173
# Backend:  mvn spring-boot:run → http://localhost:8080
VITE_API_BASE_URL=http://localhost:8080/api/v1

# Optional overrides (defaults are embedded in src/config/googleMaps.ts and backend application.yml)
# VITE_GOOGLE_MAPS_API_KEY=
# VITE_GOOGLE_MAPS_KEY=
# GOOGLE_PLACES_API_KEY=
